# ===== AI provider switch =====
# Set to "ollama" for local dev (free), "ollama-cloud" for Ollama Pro cloud models,
# or "anthropic" for production Claude API.
AI_PROVIDER=ollama-cloud

# --- Ollama (local, free) ---
# Install: https://ollama.com/download  then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# --- Ollama Cloud (Pro plan, $20/mo covers it) ---
# Get key: https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=qwen2.5:72b-instruct-q8_0

# --- Anthropic (cloud, ~$0.25-3 per 1M tokens) ---
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ===== Lead capture =====
# Where contact form submissions go. Resend recommended: https://resend.com
CONTACT_EMAIL=hello@ventrixagency.com
RESEND_API_KEY=

# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://ventrixagency.com
NEXT_PUBLIC_BUSINESS_NAME=Ventrix Agency
NEXT_PUBLIC_PHONE=