# ===== AI provider switch =====
# Set to "ollama" for local dev (free), "anthropic" for production (paid).
AI_PROVIDER=ollama

# --- Ollama (local, free) ---
# Install: https://ollama.com/download  then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# --- Anthropic (cloud, ~$0.25-3 per 1M tokens) ---
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ===== Lead capture =====
# Where contact form submissions go. Resend recommended: https://resend.com
CONTACT_EMAIL=hello@ventrixagency.com
RESEND_API_KEY=

# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://ventrixagency.com
NEXT_PUBLIC_BUSINESS_NAME=Ventrix Agency
NEXT_PUBLIC_PHONE=